# =============================================================================
# Frontend Environment Configuration
# =============================================================================
# Copy to .env.local for local development (outside Docker)
# When running with Docker, use the root .env file instead
# =============================================================================

# API URL - Backend endpoint
# For local dev: http://localhost:3000
# For Docker: http://backend:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Better Auth Configuration
# Generate a secure secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-please-use-openssl-rand-base64-32
BETTER_AUTH_DATABASE_URL=postgresql://smartcafe:smartcafe@localhost:5433/smartcafe

# Admin credentials for seeding
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=S3cur3!T0rch!91Aq
