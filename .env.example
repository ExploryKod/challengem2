# =============================================================================
# Smart Cafe - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=smartcafe
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_DB=smartcafe

# Port mapping for development (optional, defaults shown)
POSTGRES_PORT=5433

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
# Port mapping for development (optional, defaults shown)
BACKEND_PORT=3000

# Database auto-sync (WARNING: set to false in production!)
# When true, TypeORM will auto-apply schema changes - can cause data loss
DATABASE_SYNCHRONIZE=false

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
# Port exposed to host (optional, defaults shown)
FRONTEND_PORT=3001

# API URL for frontend to connect to backend (browser-accessible URL)
# IMPORTANT: This URL must be reachable from the user's browser, not just Docker network
# For production with reverse proxy: https://api.yourdomain.com
# For local Docker development: http://localhost:3000 (backend port must be exposed)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Better Auth configuration
BETTER_AUTH_SECRET=generate-a-secure-random-string-at-least-32-chars
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-admin-password

# -----------------------------------------------------------------------------
# Development Tools (only used with docker-compose.override.yml)
# -----------------------------------------------------------------------------
ADMINER_PORT=8088
